/**
 * witness-cigaw-webrtc.js
 * Handles Acoustic Proximity Discovery and WebRTC Peer-to-Peer Co-signing
 */

const SIGNALING_SERVER_URL = 'wss://relay.indivisa.net'; // Ephemeral signaling relay

class CigawAcousticWebRTC {
  constructor(localEvidenceHash) {
    this.localEvidenceHash = localEvidenceHash;
    this.peerConnection = new RTCPeerConnection({
      iceServers: [{ urls: 'stun:stun.l.google.com:19302' }] // For NAT traversal
    });
    this.dataChannel = null;
    this.signalingSocket = null;
    this.ephemeralSessionId = null;
    this.keyPair = null;
  }

  /**
   * Step 1: Initialize the local ECDSA Keys for this session
   */
  async initCrypto() {
    this.keyPair = await window.crypto.subtle.generateKey(
      { name: 'ECDSA', namedCurve: 'P-256' },
      true, 
      ['sign', 'verify']
    );
    console.log('CIGaW: WebRTC local keys generated.');
  }

  /**
   * Step 2 (Prover Role): Generate Token, Broadcast Audio, and Wait for WebRTC
   */
  async startAsProver() {
    await this.initCrypto();
    
    // Generate a short, 4-byte ephemeral token for acoustic transmission
    this.ephemeralSessionId = Math.floor(Math.random() * 0xFFFFFFFF).toString(16);
    
    // 1. Connect to the signaling relay using the token as a room ID
    this.connectSignaling(this.ephemeralSessionId, 'prover');

    // 2. Create the WebRTC Data Channel for the cryptographic exchange
    this.dataChannel = this.peerConnection.createDataChannel('cigaw-crypto-channel');
    this.setupDataChannel(this.dataChannel);

    // 3. Broadcast the token via Ultrasound (Requires an acoustic library like quiet-js)
    console.log(`Broadcasting Acoustic Token: ${this.ephemeralSessionId}`);
    this.transmitAcousticToken(this.ephemeralSessionId);

    // 4. Create and send WebRTC Offer via signaling server
    const offer = await this.peerConnection.createOffer();
    await this.peerConnection.setLocalDescription(offer);
    this.signalingSocket.send(JSON.stringify({ type: 'offer', sdp: offer, room: this.ephemeralSessionId }));
  }

  /**
   * Step 2 (Witness Role): Listen for Audio, Decode Token, and Connect WebRTC
   */
  async startAsWitness() {
    await this.initCrypto();

    console.log('Listening for Acoustic Token...');
    // Listen via microphone (Requires an acoustic library like quiet-js)
    this.ephemeralSessionId = await this.receiveAcousticToken();
    console.log(`Discovered Prover Token: ${this.ephemeralSessionId}`);

    // 1. Connect to signaling relay to rendezvous with the Prover
    this.connectSignaling(this.ephemeralSessionId, 'witness');

    // 2. Listen for the Prover's Data Channel
    this.peerConnection.ondatachannel = (event) => {
      this.dataChannel = event.channel;
      this.setupDataChannel(this.dataChannel);
    };
  }

  /**
   * Step 3: WebRTC Signaling Handshake (Abstracted)
   */
  connectSignaling(roomId, role) {
    this.signalingSocket = new WebSocket(SIGNALING_SERVER_URL);
    
    this.signalingSocket.onopen = () => {
      this.signalingSocket.send(JSON.stringify({ type: 'join', room: roomId, role: role }));
    };

    this.signalingSocket.onmessage = async (message) => {
      const data = JSON.parse(message.data);
      
      if (data.type === 'offer' && role === 'witness') {
        await this.peerConnection.setRemoteDescription(new RTCSessionDescription(data.sdp));
        const answer = await this.peerConnection.createAnswer();
        await this.peerConnection.setLocalDescription(answer);
        this.signalingSocket.send(JSON.stringify({ type: 'answer', sdp: answer, room: roomId }));
      } 
      else if (data.type === 'answer' && role === 'prover') {
        await this.peerConnection.setRemoteDescription(new RTCSessionDescription(data.sdp));
      } 
      else if (data.type === 'ice-candidate') {
        await this.peerConnection.addIceCandidate(new RTCIceCandidate(data.candidate));
      }
    };

    // Send ICE candidates to peer as they are discovered
    this.peerConnection.onicecandidate = (event) => {
      if (event.candidate) {
        this.signalingSocket.send(JSON.stringify({ type: 'ice-candidate', candidate: event.candidate, room: roomId }));
      }
    };
  }

  /**
   * Step 4: Execute the Zero-Trust Cryptographic Exchange over WebRTC
   */
  setupDataChannel(channel) {
    channel.onopen = async () => {
      console.log('WebRTC P2P Data Channel Open. Disconnecting from signaling relay.');
      this.signalingSocket.close(); // Abandon relay, connection is now purely local/P2P

      // Send local public key and challenge (Evidence Hash) to the peer
      const pubKey = await window.crypto.subtle.exportKey('raw', this.keyPair.publicKey);
      
      const payload = {
        type: 'cigaw_challenge',
        publicKey: Array.from(new Uint8Array(pubKey)),
        evidenceHash: Array.from(new Uint8Array(this.localEvidenceHash))
      };
      
      channel.send(JSON.stringify(payload));
    };

    channel.onmessage = async (event) => {
      const data = JSON.parse(event.data);

      if (data.type === 'cigaw_challenge') {
        // Peer sent their challenge. We must sign (Peer Evidence Hash + Our Evidence Hash)
        const peerHashArray = new Uint8Array(data.evidenceHash);
        const combinedBuffer = this._concatBuffers(peerHashArray.buffer, this.localEvidenceHash);
        
        const signature = await window.crypto.subtle.sign(
          { name: 'ECDSA', hash: { name: 'SHA-256' } },
          this.keyPair.privateKey,
          combinedBuffer
        );

        // Send the signature back to the peer
        channel.send(JSON.stringify({
          type: 'cigaw_signature',
          signature: Array.from(new Uint8Array(signature))
        }));
      } 
      else if (data.type === 'cigaw_signature') {
        console.log('CIGaW Handshake Complete. Signature received from peer.');
        const peerSignature = new Uint8Array(data.signature).buffer;
        
        // Finalize: Append this peerSignature and the peer's public key to the WITNESS receipt
        this.finalizeReceipt(peerSignature);
        channel.close();
      }
    };
  }

